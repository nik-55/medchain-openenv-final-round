# ─────────────────────────────────────────────
# MedChain — environment variable reference
# Copy to .env and fill in your values.
# .env is gitignored; this file is safe to commit.
# ─────────────────────────────────────────────


# ── Secrets ───────────────────────────────────

# HuggingFace token — used as the API key for HF Inference Router
# and for pushing/pulling model checkpoints (collect_rollouts, train scripts).
HF_TOKEN=hf_...

# Fallback API key when not using HF Router (e.g. OpenAI, Together, Groq).
# HF_TOKEN takes precedence if both are set.
API_KEY=

# W&B key for training run logging (train_colab.py, train_hf_jobs*.py).
WANDB_API_KEY=


# ── LLM / Inference ───────────────────────────

# OpenAI-compatible base URL for the model router.
# Default: https://router.huggingface.co/v1
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for the MedChain agent (eval + server LLM mode).
# Default: openai/gpt-oss-20b:groq
MODEL_NAME=openai/gpt-oss-20b:groq

# Separate model for ward actors when WARD_ACTOR_MODE=llm.
# Falls back to MODEL_NAME if unset.
WARD_MODEL_NAME=


# ── Server runtime flags ──────────────────────

# Ward actor behaviour: "scripted" (default, deterministic) or "llm".
WARD_ACTOR_MODE=scripted

# Clinical arbiter behaviour: "scripted" (default, deterministic) or "llm".
ARBITER_MODE=scripted

# Log verbosity for run_llm_eval.py. Default: INFO
LOG_LEVEL=INFO


# ── run_llm_eval.py ───────────────────────────

# Comma-separated seeds to evaluate. Default: 0,1,2
SEEDS=0,1,2

# Comma-separated difficulty levels. Default: light,medium,heavy
DIFFICULTIES=light,medium,heavy

# Number of rollouts per (seed, difficulty) pair. Default: 1
ROLLOUTS=1

# Seconds to sleep between API calls (rate-limit buffer). Default: 0.5
SLEEP=0.5


# ── Training (Colab / HF Jobs) ────────────────

# Base Qwen model to fine-tune. Default: Qwen/Qwen3.5-4B
MODEL_ID=Qwen/Qwen3.5-4B

# Path to pre-collected rollouts for offline training.
# Default: rollouts.jsonl  (used by train_hf_jobs_offline.py)
ROLLOUTS_FILE=artifacts/rollouts.jsonl

# PyTorch CUDA memory allocator setting (set automatically by train scripts).
# Override here only if you hit OOM on a non-standard GPU.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True


# ── run_trained_model.py ──────────────────────

# WebSocket URL of the running OpenEnv server.
SERVER_URL=http://localhost:8000

# Episode seed (0–49 train, 50–59 held-out eval).
SEED=0

# Episode difficulty: light | medium | heavy
DIFFICULTY=medium

# Path to a LoRA checkpoint directory. Leave empty to use the base model.
CHECKPOINT=
